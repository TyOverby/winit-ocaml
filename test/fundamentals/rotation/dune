(executable
 (name rotation)
 (modules rotation)
 (libraries wgpu core core_unix test_util gg)
 (preprocess
  (pps ppx_jane)))

(rule
 (alias runtest)
 (action
  (run ./rotation.exe))
 (targets
  rotation_0deg.png
  rotation_45deg.png
  rotation_90deg.png
  rotation_180deg.png))

(rule
 (alias runtest)
 (action
  (cmp rotation_0deg.expected.png rotation_0deg.png)))

(rule
 (alias runtest)
 (action
  (cmp rotation_45deg.expected.png rotation_45deg.png)))

(rule
 (alias runtest)
 (action
  (cmp rotation_90deg.expected.png rotation_90deg.png)))

(rule
 (alias runtest)
 (action
  (cmp rotation_180deg.expected.png rotation_180deg.png)))

