(executables
 (names
  cameras_direct_math
  cameras_camera_aim
  cameras_look_at
  cameras_aim_fs)
 (libraries wgpu core core_unix test_util gg)
 (preprocess
  (pps ppx_jane)))

; cameras_direct_math.exe rules

(rule
 (alias runtest)
 (action
  (run ./cameras_direct_math.exe))
 (targets
  cameras_direct_math_0deg.png
  cameras_direct_math_45deg.png
  cameras_direct_math_90deg.png
  cameras_direct_math_180deg.png)
 (mode promote))

(rule
 (alias runtest)
 (deps
  "../../../imgdiff.sh"
  cameras_direct_math_0deg.expected.png
  cameras_direct_math_0deg.png)
 (action
  (bash "%{deps}")))

(rule
 (alias runtest)
 (deps
  "../../../imgdiff.sh"
  cameras_direct_math_45deg.expected.png
  cameras_direct_math_45deg.png)
 (action
  (bash "%{deps}")))

(rule
 (alias runtest)
 (deps
  "../../../imgdiff.sh"
  cameras_direct_math_90deg.expected.png
  cameras_direct_math_90deg.png)
 (action
  (bash "%{deps}")))

(rule
