(library
 (name wgpu)
 (public_name wgpu)
 (libraries wgpu_low))

(rule
 (deps
  (source_tree ../codegen/templates))
 (action
  (with-stdout-to
   enums.ml
   (pipe-stdout
    (run ../codegen/gen_bindings.exe High Enums_ml)
    (run ocamlformat --impl -))))
 (mode promote)
 (target enums.ml))

(rule
 (deps
  (source_tree ../codegen/templates))
 (action
  (with-stdout-to
   enums.mli
   (pipe-stdout
    (run ../codegen/gen_bindings.exe High Enums_mli)
    (run ocamlformat --intf -))))
 (mode promote)
 (target enums.mli))

