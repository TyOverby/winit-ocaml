(executables
 (names
  simple_triangle_storage_minimal
  simple_triangle_storage_split
  storage_buffer_vertices)
 (libraries wgpu core core_unix test_util)
 (preprocess
  (pps ppx_jane)))

; simple_triangle_storage_minimal.exe rules

(rule
 (alias runtest)
 (action
  (run ./simple_triangle_storage_minimal.exe))
 (targets simple_triangle_storage_minimal.png)
 (mode promote))

(rule
 (alias runtest)
 (deps
  "../../../imgdiff.sh"
  simple_triangle_storage_minimal.expected.png
  simple_triangle_storage_minimal.png)
 (action
  (bash "%{deps}")))

